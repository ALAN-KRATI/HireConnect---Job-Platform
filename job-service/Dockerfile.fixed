FROM eclipse-temurin:21-jre

RUN apt-get update && apt-get install -y curl

WORKDIR /app

COPY --from=builder /app/target/*.jar app.jar

EXPOSE 8083

CMD ["sh", "-c", "sleep 15 ^&^& java -jar app.jar"]
