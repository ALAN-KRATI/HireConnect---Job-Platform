{
  "properties": {
    "jobId": {
      "type": "long"
    },
    "title": {
      "type": "text",
      "analyzer": "job_analyzer",
      "search_analyzer": "job_search_analyzer",
      "fields": {
        "keyword": {
          "type": "keyword",
          "ignore_above": 256
        }
      }
    },
    "category": {
      "type": "keyword"
    },
    "type": {
      "type": "keyword"
    },
    "location": {
      "type": "text",
      "analyzer": "standard",
      "fields": {
        "keyword": {
          "type": "keyword",
          "ignore_above": 256
        }
      }
    },
    "minSalary": {
      "type": "double"
    },
    "maxSalary": {
      "type": "double"
    },
    "description": {
      "type": "text",
      "analyzer": "job_analyzer",
      "search_analyzer": "job_search_analyzer"
    },
    "skills": {
      "type": "keyword"
    },
    "experienceRequired": {
      "type": "integer"
    },
    "postedBy": {
      "type": "long"
    },
    "status": {
      "type": "keyword"
    },
    "postedAt": {
      "type": "date",
      "format": "yyyy-MM-dd'T'HH:mm:ss||epoch_millis"
    },
    "viewCount": {
      "type": "long"
    }
  },
  "dynamic_templates": [
    {
      "strings_as_keywords": {
        "match_mapping_type": "string",
        "mapping": {
          "type": "keyword"
        }
      }
    }
  ]
