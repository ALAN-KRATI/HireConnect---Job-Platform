# ===========================================
# HireConnect Environment Variables Template
# Copy this file to .env and override values as needed.
# docker-compose.yml already provides sane defaults, so you only
# need to set values that differ from the defaults below.
# ===========================================

# Database
DB_PASSWORD=root123
MYSQL_ROOT_PASSWORD=root123

# GitHub OAuth (Auth Service) - provide your own for GitHub login to work
GITHUB_CLIENT_ID=Ov23liSZyYkROmakVP1a
GITHUB_CLIENT_SECRET=187f01d5f569679045636c46381ab5e61edd476e

# JWT
JWT_SECRET=hireconnect-super-secret-key-for-jwt-123456789-hireconnect-auth-service

# Stripe (Subscription Service) - test-mode keys by default
STRIPE_SECRET_KEY=sk_test_example_key_12345
STRIPE_PUBLISHABLE_KEY=pk_test_example_key_67890
STRIPE_WEBHOOK_SECRET=whsec_example_webhook_secret

# Mail (Notification Service)
MAIL_USERNAME=test@example.com
MAIL_PASSWORD=testpass123

# URLs (defaults assume docker compose serves frontend on http://localhost)
STRIPE_SUCCESS_URL=http://localhost/payment/success
STRIPE_CANCEL_URL=http://localhost/payment/cancel
FRONTEND_URL=http://localhost
