# ============================================
# HireConnect Docker Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
DB_PASSWORD=your_secure_mysql_password_here

# ============================================
# GitHub OAuth Configuration
# ============================================
# Get these from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============================================
# JWT Configuration
# ============================================
# Generate a secure random key (at least 256 bits)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# ============================================
# Email Configuration (Optional)
# ============================================
# For notification emails - use Gmail App Password
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ============================================
# Frontend Configuration (Optional)
# ============================================
# React app API URL (change if deploying externally)
VITE_API_URL=http://localhost:8080

# ============================================
# Notes:
# ============================================
# 1. Never commit .env file with real values
# 2. DB_PASSWORD must match existing MySQL root password if database already initialized
# 3. GitHub OAuth callback URL should be: http://localhost:8080/login/oauth2/code/github
# 4. For production, use strong passwords and proper SSL certificates